# À copier dans la racine du repo sur le VPS : cp deploy/app-env.example .env
# Puis renseigner les valeurs (surtout DATABASE_URL, NEXTAUTH_SECRET, NEXTAUTH_URL, Google OAuth).

# NextAuth (obligatoire en prod)
# NEXTAUTH_URL doit être EXACTEMENT l’URL publique de l’app (https, pas http).
NEXTAUTH_SECRET=    # openssl rand -hex 32
NEXTAUTH_URL=https://app.blueprint-modular.com

# Si les modules (Documents, Contrats, Wiki, Sandbox IA) renvoient 401 sans être connecté :
# mettre SKIP_AUTH_FOR_TEST=true pour utiliser le 1er utilisateur en base (tests/démo).
# Prérequis : au moins un utilisateur créé (inscription ou OAuth une fois).
# SKIP_AUTH_FOR_TEST=true

# OAuth (Google pour la connexion)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Base de données (obligatoire)
DATABASE_URL=postgresql://user:password@localhost:5432/blueprint_modular

# Optionnel : autres OAuth, clés IA, etc.
# APPLE_ID= ...
# ANTHROPIC_API_KEY= ...

# Service Whisper (transcription vocale — Wiki, Assistant IA)
# URL du micro-service faster-whisper (port 9000 sur le VPS)
# WHISPER_SERVICE_URL=http://localhost:9000
