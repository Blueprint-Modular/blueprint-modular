generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  picture   String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiKeys         ApiKey[]
  wikiArticles    WikiArticle[]     @relation("Author")
  documents       Document[]
  contracts       Contract[]
  aiConversations AiConversation[]
}

enum Role {
  OWNER
  ADMIN
  USER
}

model ApiKey {
  id           String   @id @default(cuid())
  userId       String
  provider     String
  keyEncrypted String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WikiArticle {
  id                 String    @id @default(cuid())
  title              String
  content            String    @db.Text
  slug               String    @unique
  parentId           String?
  authorId           String
  isPublished        Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  embeddingVector    String?   @db.Text // JSON array du vecteur (pgvector / RAG)
  embeddingAt        DateTime?
  excerpt            String?   @db.Text
  tags               String[]  @default([])
  coverImage         String?   @map("cover_image")
  authorName         String?   @map("author_name")
  lastRevisedBy      String?   @map("last_revised_by")
  readingTimeMinutes Int?      @map("reading_time_minutes")
  wordCount          Int?      @map("word_count")
  viewCount          Int       @default(0) @map("view_count")
  pinned             Boolean   @default(false) @map("pinned")
  template           String?   @map("template")
  parent             WikiArticle?   @relation("WikiHierarchy", fields: [parentId], references: [id])
  children           WikiArticle[]  @relation("WikiHierarchy")
  author             User          @relation("Author", fields: [authorId], references: [id], onDelete: Cascade)
  revisions          WikiRevision[]
  comments           WikiComment[]
  backlinksFrom      WikiBacklink[] @relation("WikiBacklinkSource")
  backlinksTo        WikiBacklink[] @relation("WikiBacklinkTarget")
}

model WikiRevision {
  id         String     @id @default(cuid())
  articleId  String     @map("article_id")
  content    String     @db.Text
  authorId   String?     @map("author_id")
  authorName String?    @map("author_name")
  changeNote String?    @map("change_note") @db.Text
  createdAt  DateTime   @default(now()) @map("created_at")
  article    WikiArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model WikiComment {
  id         String     @id @default(cuid())
  articleId  String     @map("article_id")
  content    String     @db.Text
  authorId   String?    @map("author_id")
  authorName String?    @map("author_name")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  article    WikiArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model WikiBacklink {
  id               String     @id @default(cuid())
  sourceArticleId  String     @map("source_article_id")
  targetArticleId  String     @map("target_article_id")
  createdAt        DateTime   @default(now()) @map("created_at")
  source           WikiArticle @relation("WikiBacklinkSource", fields: [sourceArticleId], references: [id], onDelete: Cascade)
  target           WikiArticle @relation("WikiBacklinkTarget", fields: [targetArticleId], references: [id], onDelete: Cascade)
  @@unique([sourceArticleId, targetArticleId])
  @@index([targetArticleId])
}

model Document {
  id             String   @id @default(cuid())
  filename       String
  mimeType       String
  filePath       String?
  uploadedById   String
  analysisStatus String   @default("pending")
  supplier       String?
  client         String?
  contractDate   DateTime?
  signatureDate  DateTime?
  terminationDate DateTime?
  summary        String?  @db.Text
  keyPoints      String?  @db.Text
  commitments    String?  @db.Text
  rawText        String?  @db.Text
  createdAt      DateTime @default(now())
  uploadedBy     User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
}

model Contract {
  id                String    @id @default(cuid())
  title             String
  contractType      String    @map("contract_type")   // 'supplier' | 'cgv' | 'other'
  workspace         String    // 'nxtfood' | 'beam'
  filePath          String    @map("file_path")
  fileHash          String    @map("file_hash")
  originalFilename  String    @map("original_filename")
  fileSizeBytes     Int       @map("file_size_bytes")
  status            String    @default("pending")    // 'pending' | 'analyzing' | 'done' | 'error'
  analysisProgress  Int       @default(0) @map("analysis_progress")
  extractedData     Json?     @map("extracted_data")
  createdAt         DateTime  @default(now()) @map("created_at")
  analyzedAt        DateTime? @map("analyzed_at")
  embeddingVector   String?   @map("embedding_vector") @db.Text  // JSON array du vecteur
  embeddingAt       DateTime? @map("embedding_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  uploadedById      String    @map("uploaded_by_id")
  uploadedBy        User      @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
}

model AiConversation {
  id        String   @id @default(cuid())
  userId    String
  preview   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AiMessage[]
}

model AiMessage {
  id             String   @id @default(cuid())
  conversationId String
  userMessage    String   @db.Text
  aiResponse     String   @db.Text
  providerName   String
  createdAt      DateTime @default(now())
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}
