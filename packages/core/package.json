{
  "name": "@blueprint-modular/core",
  "version": "0.2.0",
  "description": "Blueprint Modular — composants React pour apps de données",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/packages/core/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/packages/core/src/index.d.ts"
    },
    "./schema": {
      "import": "./dist/schema/index.js",
      "require": "./dist/schema/index.js",
      "types": "./dist/schema/index.d.ts"
    },
    "./style.css": "./dist/style.css",
    "./dist/style.css": "./dist/style.css"
  },
  "files": [
    "dist/",
    "USAGE.md"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "leaflet": ">=1.9.0",
    "react-leaflet": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "leaflet": { "optional": true },
    "react-leaflet": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-dts": "^4.3.0"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "zod": "^4.3.6"
  }
}
