# NextAuth
NEXTAUTH_SECRET=generate-with-openssl-rand-hex-32
NEXTAUTH_URL=http://localhost:3000

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# bpm.auth (optionnel) — whitelist d’emails autorisés (vide = tous). Connexion e-mail : CREDENTIALS_DEMO_PASSWORD pour les comptes whitelist.
# AUTHORIZED_EMAILS=user@example.com,admin@example.com
# CREDENTIALS_DEMO_PASSWORD=
APPLE_ID=
APPLE_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/blueprint_modular

# AI (optionnel)
# Ollama local : sans clé, l'assistant et l'analyse de documents utilisent Qwen3.
AI_SERVER_URL=http://localhost:11434
AI_MODEL=qwen3:8b
AI_MOCK=false
AI_TIMEOUT=120

# Pour le Monitor (téléprompte) : saisir la clé dans l’interface 🔑, pas dans .env
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
AI_ENCRYPTION_KEY=

# Test sans connexion : avec SKIP_AUTH_FOR_TEST=true, IA / Wiki / Documents utilisent le 1er user en base (déconseillé en prod).
# SKIP_AUTH_FOR_TEST=true

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
