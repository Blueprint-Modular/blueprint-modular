{
  "name": "blueprint-modular",
  "version": "0.1.60",
  "private": true,
  "scripts": {
    "clean": "node scripts/clear-cache.cjs",
    "dev": "next dev",
    "build": "next build",
    "build:standalone": "next build && bash deploy/copy-standalone-assets.sh",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate --schema=prisma/schema.prisma",
    "generate:components": "python scripts/generate-bpm-components-json.py",
    "generate:llms": "python scripts/generate-llms-txt.py",
    "deploy": "echo 'Deploy: run .\\\\scripts\\\\deploy-vps-remote.ps1 (PowerShell) — une commande SSH qui lance deploy/deploy.sh sur le VPS'",
    "publish:core": "cd packages/core && npm install && npm run build && npm publish --access public",
    "version:sync": "node scripts/sync-version.js",
    "build:modules-bundle": "node scripts/build-modules-bundle.cjs",
    "seed:wiki": "node prisma/seed-wiki-procedures.cjs",
    "seed:production": "npx tsx prisma/seed-production.ts"
  },
  "prisma": {
    "seed": "node prisma/seed-wiki-procedures.cjs"
  },
  "dependencies": {
    "@blueprint-modular/core": "file:packages/core",
    "@anthropic-ai/sdk": "^0.78.0",
    "leaflet": "^1.9.4",
    "react-leaflet": "^4.2.1",
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^5.22.0",
    "@tanstack/react-query": "^5.59.20",
    "archiver": "^7.0.1",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^0.460.0",
    "mammoth": "^1.11.0",
    "next": "^16.1.6",
    "next-auth": "^4.24.10",
    "pdf-parse": "^1.1.1",
    "pdf2pic": "^3.2.0",
    "plotly.js": "^2.35.3",
    "prisma": "^5.22.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-plotly.js": "^2.6.0",
    "rehype-highlight": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "sharp": "^0.34.5",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/leaflet": "^1.9.8",
    "@types/node": "^22.9.0",
    "@types/plotly.js": "^2.35.14",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-plotly.js": "^2.6.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  }
}
