# Application
NEXTAUTH_SECRET=your_secret_here
NEXTAUTH_URL=https://app.blueprint-modular.com
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# OAuth Google (optionnel)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# IA — Ollama
AI_SERVER_URL=http://localhost:11434
AI_MODEL=qwen2.5:7b
AI_TIMEOUT=120
AI_MAX_RETRIES=2
AI_MOCK=false

# IA — Anthropic (optionnel, si clé disponible)
ANTHROPIC_API_KEY=

# Auth test (désactiver en prod)
SKIP_AUTH_FOR_TEST=false
